rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // ─── NOTE ───────────────────────────────────────────────────
    // This app does NOT use Firebase Auth yet.
    // Authentication is handled client-side via email + PIN.
    // These rules are intentionally permissive for now.
    // They serve as DOCUMENTATION of the data model and as a
    // starting point for when Firebase Auth is added.
    // ─────────────────────────────────────────────────────────────

    // New-schema collections (active)
    match /profils/{profilId} {
      allow read, write: if true;
    }
    match /familles/{familleId} {
      allow read, write: if true;
    }
    match /famille_membres/{membreId} {
      allow read, write: if true;
    }
    match /ressources/{ressourceId} {
      allow read, write: if true;
    }
    match /reservations/{reservationId} {
      allow read, write: if true;
    }
    match /acces_ressource/{accessId} {
      allow read, write: if true;
    }
    match /checklist_statuts/{docId} {
      allow read, write: if true;
    }
    match /evenements_sejour/{docId} {
      allow read, write: if true;
    }
    match /guides_maison/{docId} {
      allow read, write: if true;
    }

    // Legacy collections (read-only — kept for migration stragglers)
    match /families/{familyId} {
      allow read: if true;
      allow write: if false;
      match /{subcol}/{docId} {
        allow read: if true;
        allow write: if false;
      }
    }
    match /users/{userId} {
      allow read: if true;
      allow write: if false;
    }
    match /resource_access/{docId} {
      allow read: if true;
      allow write: if false;
    }
    match /config/{docId} {
      allow read: if true;
      allow write: if false;
    }

    // Deny everything else
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
